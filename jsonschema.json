{
  "title": "The JSON Schema Standard Library",
  "description": "A growing collection of hand-crafted high-quality schemas by Sourcemeta",
  "email": "hello@sourcemeta.com",
  "github": "sourcemeta/std",
  "path": "./schemas",
  "resolve": {
    "urn:sourcemeta:std:ietf:jsonschema:2020-12:dialect:format-assertion": "./schemas/2020-12/ietf/jsonschema/2020-12/dialect/format-assertion.json"
  },
  "lint": {
    "rules": [
      "./rules/comment.json",
      "./rules/dialect.json",
      "./rules/identifiers.json",
      "./rules/license.json",
      "./rules/links.json",
      "./rules/single-line-text.json",
      "./rules/symbol.json",
      { "path": "./rules/root.json", "topLevel": true }
    ]
  }
}
